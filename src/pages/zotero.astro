<style>
/* ── Zotero page–specific styles ──────────────────────────── */

.zot-title-row {
  display: flex;
  align-items: baseline;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 16px;
}
.zot-title-row .page-title { margin-bottom: 0; }

.zot-lang-link {
  font-size: 14px;
  color: #888888;
  text-decoration: none;
  transition: color .15s;
  white-space: nowrap;
}
.zot-lang-link:hover { color: #111111; }
[data-theme="dark"] .zot-lang-link { color: #666666; }
[data-theme="dark"] .zot-lang-link:hover { color: #EEEEEE; }

.zot-badge-row {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 20px;
}
.zot-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  font-weight: 500;
  padding: 3px 10px;
  border-radius: 100px;
  background: #F5F4F0;
  color: #3D3D3D;
  border: 1px solid #E0DED8;
  white-space: nowrap;
}
[data-theme="dark"] .zot-badge {
  background: #1A1A1A;
  color: #AAAAAA;
  border-color: #333333;
}
.zot-badge-link {
  text-decoration: none;
  transition: background .15s, color .15s;
}
.zot-badge-link:hover {
  background: #ECEAE3;
  color: #111111;
}
[data-theme="dark"] .zot-badge-link:hover {
  background: #252525;
  color: #EEEEEE;
}

.zot-dev {
  font-size: 14px;
  color: #888888;
  line-height: 1.65;
  margin-bottom: 24px;
  max-width: 660px;
}
[data-theme="dark"] .zot-dev { color: #666666; }

/* Two-column workflow summary */
.zot-two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin: 32px 0;
}
@media (max-width: 600px) { .zot-two-col { grid-template-columns: 1fr; } }

.zot-workflow-card {
  background: #F5F4F0;
  border-radius: 8px;
  padding: 20px 24px;
}
[data-theme="dark"] .zot-workflow-card { background: #1A1A1A; }
.zot-workflow-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #888888;
  margin-bottom: 10px;
}
[data-theme="dark"] .zot-workflow-label { color: #666666; }
.zot-workflow-card p {
  font-size: 14px;
  line-height: 1.65;
  color: #3D3D3D;
  margin: 0;
}
[data-theme="dark"] .zot-workflow-card p { color: #AAAAAA; }

/* Collapsible details */
.zot-details {
  border: 1px solid #E0DED8;
  border-radius: 8px;
  margin: 24px 0;
  overflow: hidden;
}
[data-theme="dark"] .zot-details { border-color: #333333; }
.zot-details > summary {
  padding: 14px 20px;
  font-size: 15px;
  font-weight: 500;
  color: #3D3D3D;
  cursor: pointer;
  user-select: none;
  list-style: none;
  display: flex;
  align-items: center;
  gap: 8px;
  background: #F5F4F0;
  transition: background .15s;
}
.zot-details > summary::-webkit-details-marker { display: none; }
.zot-details > summary::before {
  content: '▶';
  font-size: 10px;
  color: #888888;
  transition: transform .2s;
  flex-shrink: 0;
}
.zot-details[open] > summary::before { transform: rotate(90deg); }
.zot-details > summary:hover { background: #ECEAE3; }
[data-theme="dark"] .zot-details > summary { background: #1A1A1A; color: #AAAAAA; }
[data-theme="dark"] .zot-details > summary:hover { background: #222222; }
.zot-details-body {
  padding: 20px 24px;
  border-top: 1px solid #E0DED8;
}
[data-theme="dark"] .zot-details-body { border-top-color: #333333; }
.zot-details-body p {
  font-size: 15px;
  line-height: 1.7;
  color: #3D3D3D;
  margin-bottom: 12px;
}
.zot-details-body p:last-child { margin-bottom: 0; }
[data-theme="dark"] .zot-details-body p { color: #AAAAAA; }

/* Callout boxes */
.zot-callout {
  border-radius: 6px;
  padding: 14px 18px;
  margin: 16px 0;
  font-size: 14px;
  line-height: 1.65;
  border-left: 3px solid;
}
.zot-callout-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.zot-callout-tip    { background: #F0FAF0; border-color: #22C55E; color: #1A5C2A; }
.zot-callout-tip    .zot-callout-label { color: #16A34A; }
.zot-callout-note   { background: #EFF6FF; border-color: #60A5FA; color: #1E3A5F; }
.zot-callout-note   .zot-callout-label { color: #2563EB; }
.zot-callout-important { background: #FFF7ED; border-color: #FB923C; color: #7C2D12; }
.zot-callout-important .zot-callout-label { color: #EA580C; }
.zot-callout-warning { background: #FEF2F2; border-color: #F87171; color: #7F1D1D; }
.zot-callout-warning .zot-callout-label { color: #DC2626; }

[data-theme="dark"] .zot-callout-tip    { background: #052E16; color: #86EFAC; }
[data-theme="dark"] .zot-callout-tip    .zot-callout-label { color: #4ADE80; }
[data-theme="dark"] .zot-callout-note   { background: #0C1A2E; color: #93C5FD; }
[data-theme="dark"] .zot-callout-note   .zot-callout-label { color: #60A5FA; }
[data-theme="dark"] .zot-callout-important { background: #2D1506; color: #FDBA74; }
[data-theme="dark"] .zot-callout-important .zot-callout-label { color: #FB923C; }
[data-theme="dark"] .zot-callout-warning { background: #2D0606; color: #FCA5A5; }
[data-theme="dark"] .zot-callout-warning .zot-callout-label { color: #F87171; }

/* Installation steps */
.zot-step {
  border: 1px solid #E0DED8;
  border-radius: 8px;
  margin-bottom: 16px;
  overflow: hidden;
}
[data-theme="dark"] .zot-step { border-color: #333333; }
.zot-step-header {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 16px 20px;
  background: #F5F4F0;
  font-size: 16px;
  font-weight: 600;
  color: #111111;
}
[data-theme="dark"] .zot-step-header { background: #1A1A1A; color: #EEEEEE; }
.zot-step-num {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #111111;
  color: #FFFFFF;
  font-size: 13px;
  font-weight: 700;
  flex-shrink: 0;
}
[data-theme="dark"] .zot-step-num { background: #EEEEEE; color: #111111; }
.zot-step-body { padding: 20px 20px 20px 20px; }
.zot-optional {
  font-size: 13px;
  font-weight: 400;
  color: #888888;
  margin-left: 4px;
}

/* h3 within docs sections */
.docs-h3 {
  font-family: 'Source Serif 4', Georgia, 'Times New Roman', serif;
  font-size: 18px;
  font-weight: 600;
  letter-spacing: -0.01em;
  color: #111111;
  margin-top: 32px;
  margin-bottom: 12px;
}
[data-theme="dark"] .docs-h3 { color: #EEEEEE; }

/* Citation example block */
.zot-citation-block {
  background: #F5F4F0;
  border-left: 3px solid #D0CEC9;
  border-radius: 0 6px 6px 0;
  padding: 16px 20px;
  font-family: 'IBM Plex Mono', 'Courier New', monospace;
  font-size: 13px;
  line-height: 1.7;
  color: #3D3D3D;
  margin: 16px 0;
}
[data-theme="dark"] .zot-citation-block {
  background: #1A1A1A;
  border-color: #444444;
  color: #AAAAAA;
}
.zot-citation-block em { font-style: italic; }

/* Sub-list inside numbered steps */
.zot-sublist {
  margin-top: 8px;
  padding-left: 20px;
}

/* kbd keys */
kbd {
  display: inline-block;
  padding: 1px 6px;
  font-family: 'IBM Plex Mono', 'Courier New', monospace;
  font-size: 12px;
  color: #3D3D3D;
  background: #F5F4F0;
  border: 1px solid #D0CEC9;
  border-radius: 4px;
  box-shadow: 0 1px 0 #D0CEC9;
}
[data-theme="dark"] kbd { color: #AAAAAA; background: #1A1A1A; border-color: #444444; box-shadow: 0 1px 0 #444444; }

/* Small text variant */
.zot-small { font-size: 13px; color: #888888; }
[data-theme="dark"] .zot-small { color: #666666; }
</style>

<script>
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });

  const toggle = document.getElementById('themeToggle');
  toggle?.addEventListener('click', () => {
    const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });
</script>
