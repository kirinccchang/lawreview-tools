/* Three states: empty → archiving → done, cycling every 4.5s */
.zot-place-empty,
.zot-place-archiving,
.zot-place-done {
  position: absolute;
  left: 0; top: 0;
  white-space: nowrap;
  animation-duration: 4.5s;
  animation-iteration-count: infinite;
  animation-timing-function: ease-in-out;
}
/* Reserve space */
.zot-place-val::after { content: '[https://perma.cc/PT32-56LR] ✓'; visibility: hidden; font-size: 11px; }

.zot-place-empty    { animation-name: zot-state-empty; color: #AAAAAA; }
.zot-place-archiving{ animation-name: zot-state-archiving; color: #888888; }
.zot-place-done     { animation-name: zot-state-done; }

@keyframes zot-state-empty {
  0%,  15% { opacity: 1; }
  20%, 100% { opacity: 0; }
}
@keyframes zot-state-archiving {
  0%,  15% { opacity: 0; }
  20%, 35% { opacity: 1; }
  40%, 100% { opacity: 0; }
}
@keyframes zot-state-done {
  0%,  35% { opacity: 0; }
  45%, 90% { opacity: 1; }
