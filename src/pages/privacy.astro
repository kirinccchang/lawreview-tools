---
import Base from '../layouts/Base.astro';
---
<Base
  title="Privacy Policy — lawreview.tools"
  description="lawreview.tools privacy policy. This website does not collect, store, or transmit any personal data."
>

<nav class="navbar" id="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <span>⚖</span>
      <span class="nav-logo-text">lawreview.tools</span>
    </a>
    <div class="nav-right">
      <a href="/#tools" class="nav-link">Tools</a>
      <button class="nav-theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      </button>
    </div>
  </div>
</nav>

<main class="page-main">
  <div class="container">

    <div class="phase-label">LEGAL</div>
    <h1 class="page-title">Privacy Policy</h1>
    <p class="last-updated">Last updated: April 2026</p>

    <div class="policy-body">

      <p>
        This website does not collect, store, or transmit any personal data.
      </p>

      <h2>Documents you process</h2>
      <p>
        Documents processed by PermaDrop and SupraDrop remain entirely in your
        browser's local memory. They are never uploaded to any server.
        When you close the tab, all document data is discarded.
      </p>

      <h2>Analytics and tracking</h2>
      <p>
        No analytics. No tracking pixels. No third-party scripts that observe
        your behavior. This site uses no cookies except one: a <code>localStorage</code>
        entry that stores your dark/light mode preference.
      </p>

      <h2>External communication</h2>
      <p>
        The only external communication initiated from these tools is from your
        browser directly to the <a href="https://perma.cc" target="_blank" rel="noopener">perma.cc</a> API,
        using your own API key. This communication occurs only when you explicitly
        choose to archive a URL. No intermediary server is involved.
      </p>

      <h2>Open source</h2>
      <p>
        All tools are open source under the AGPL v3 license. The source code
        is publicly available on GitHub. You can verify exactly what runs in
        your browser.
      </p>

      <h2>Contact</h2>
      <p>
        Questions? Reach out via <a href="https://kirinchang.com" target="_blank" rel="noopener">kirinchang.com</a>.
      </p>

    </div>

    <div class="policy-footer-nav">
      <a href="/" class="btn-text-link">← Back to lawreview.tools</a>
    </div>

  </div>
</main>

<footer class="page-footer">
  <div class="container">
    <div class="footer-bottom">
      © 2026 Kirin Chang · <a href="/">lawreview.tools</a> · Open source under AGPL v3
    </div>
  </div>
</footer>

</Base>

<script>
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 100);
  }, { passive: true });
  const toggle = document.getElementById('themeToggle');
  toggle?.addEventListener('click', () => {
    const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });
</script>

<style>
.navbar {
  position: sticky; top: 0; z-index: 100; height: 56px;
  background: var(--bg); border-bottom: 1px solid transparent;
  transition: border-color 0.2s, backdrop-filter 0.2s, background 0.2s;
}
.navbar.scrolled {
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  background: var(--bg);
  border-bottom-color: var(--border);
}
.nav-inner {
  max-width: 1100px; margin: 0 auto; padding: 0 24px;
  height: 100%; display: flex; align-items: center; justify-content: space-between;
}
.nav-logo { display: flex; align-items: center; gap: 8px; text-decoration: none; }
.nav-logo-text { font-family: var(--font-display); font-size: 17px; color: var(--text); }
.nav-right { display: flex; align-items: center; gap: 20px; }
.nav-link { font-size: 14px; font-weight: 500; color: var(--text-muted); transition: color 0.15s; }
.nav-link:hover { color: var(--text); }
.nav-theme-toggle {
  display: flex; align-items: center; justify-content: center;
  width: 32px; height: 32px; border-radius: 8px; color: var(--text-muted);
  transition: color 0.15s, background 0.15s;
}
.nav-theme-toggle:hover { color: var(--text); background: var(--bg-alt); }
[data-theme="dark"] .icon-moon { display: none; }
[data-theme="light"] .icon-sun, :root:not([data-theme="dark"]) .icon-sun { display: none; }

.page-main { padding: 80px 0; }
.container { max-width: 700px; margin: 0 auto; padding: 0 24px; }

.phase-label {
  font-size: 11px; font-weight: 600; letter-spacing: 0.15em;
  text-transform: uppercase; color: var(--text-subtle); margin-bottom: 14px;
}
.page-title {
  font-family: var(--font-display); font-size: 2.5rem; font-weight: 400;
  color: var(--text); letter-spacing: -0.02em; margin-bottom: 8px;
}
.last-updated { font-size: 13px; color: var(--text-subtle); margin-bottom: 48px; }

.policy-body { display: flex; flex-direction: column; gap: 0; }
.policy-body p { font-size: 16px; color: var(--text-muted); line-height: 1.75; margin-bottom: 20px; }
.policy-body h2 {
  font-family: var(--font-display); font-size: 18px; font-weight: 400;
  color: var(--text); margin-top: 36px; margin-bottom: 12px;
  border-left: 3px solid var(--accent); padding-left: 12px;
}
.policy-body code {
  background: var(--bg-alt); padding: 2px 6px; border-radius: 4px;
  font-family: var(--font-mono); font-size: 13px;
}
.policy-body a { color: var(--accent); text-decoration: underline; text-decoration-color: transparent; transition: text-decoration-color 0.15s; }
.policy-body a:hover { text-decoration-color: var(--accent); }

.btn-text-link { font-size: 14px; color: var(--accent); text-decoration: none; font-weight: 500; transition: opacity 0.15s; }
.btn-text-link:hover { opacity: 0.75; }

.policy-footer-nav { margin-top: 64px; }

.page-footer { border-top: 1px solid var(--border); padding: 32px 0; }
.footer-bottom { font-size: 13px; color: var(--text-subtle); }
.footer-bottom a { color: var(--text-muted); transition: color 0.15s; }
.footer-bottom a:hover { color: var(--text); }
</style>
